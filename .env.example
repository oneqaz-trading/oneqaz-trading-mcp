# Server
MCP_SERVER_PORT=8010
MCP_SERVER_HOST=0.0.0.0
MCP_LOG_LEVEL=INFO

# Data directories (all paths relative to DATA_ROOT or absolute)
# DATA_ROOT=/path/to/your/data

# Market-specific overrides (optional)
# MCP_COIN_DATA_DIR=/path/to/coin/data_storage
# MCP_KR_DATA_DIR=/path/to/kr/data_storage
# MCP_US_DATA_DIR=/path/to/us/data_storage
# MCP_EXTERNAL_CONTEXT_DATA_DIR=/path/to/external_context/data_storage
# MCP_GLOBAL_REGIME_DATA_DIR=/path/to/global_regime/data_storage
